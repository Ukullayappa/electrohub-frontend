# ── Local development (.env.local) ──────────────────────────────────────
# Leave VITE_API_URL empty locally — Vite's proxy handles /api → localhost:5000
VITE_API_URL=

# ── Production (set in Vercel dashboard → Settings → Environment Variables) ──
# Your Render backend URL (no trailing slash, no /api)
# Example:
VITE_API_URL=https://electrohub-api.onrender.com
